---
import TeamGrid from "../about/TeamGrid.astro";
const { data } = Astro.props;
---

<section class="py-20 px-6">
    <div class="container mx-auto max-w-6xl">
        {
            data.headline && (
                <h2 class="text-3xl md:text-5xl font-display font-black text-center mb-16">
                    {data.headline}
                </h2>
            )
        }
        <TeamGrid />
    </div>
</section>
