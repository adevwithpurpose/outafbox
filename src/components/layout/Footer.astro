---
import Logo from "../brand/Logo.astro";
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-black relative overflow-hidden">
    <!-- Decorative background elements -->
    <div
        class="absolute top-0 left-1/4 w-96 h-96 bg-brand-purple/10 rounded-full blur-[100px] pointer-events-none"
    >
    </div>
    <div
        class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-blue/10 rounded-full blur-[100px] pointer-events-none"
    >
    </div>

    <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12 relative z-10"
    >
        <!-- Pre-Footer CTA -->
        <div
            class="glass-panel p-8 md:p-12 rounded-[2rem] text-left mb-20 border border-white/10 relative overflow-hidden group shadow-2xl"
        >
            <!-- Animated Mesh Glow -->
            <div
                class="absolute -right-24 -top-24 w-96 h-96 bg-brand-purple/20 blur-[100px] rounded-full group-hover:bg-brand-purple/30 transition-all duration-1000"
            >
            </div>
            <div
                class="absolute -left-24 -bottom-24 w-96 h-96 bg-brand-blue/20 blur-[100px] rounded-full group-hover:bg-brand-blue/30 transition-all duration-1000"
            >
            </div>

            <div
                class="relative z-10 grid lg:grid-cols-[1fr_auto] gap-8 items-center"
            >
                <div class="max-w-2xl">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-white/50 text-[10px] font-bold uppercase tracking-widest mb-4"
                    >
                        Final Step to Scale
                    </div>
                    <h2
                        class="text-3xl md:text-4xl font-black mb-4 text-white leading-tight"
                    >
                        Ready to stop <span class="text-gray-500 line-through"
                            >renting</span
                        > agencies?
                    </h2>
                    <p class="text-lg text-gray-400 font-medium">
                        Partner with an ecosystem that incentives your growth.
                        We only win when you scale.
                    </p>
                </div>
                <div>
                    <a
                        href="/audit"
                        class="inline-flex items-center gap-3 px-8 py-4 bg-white text-black font-black text-sm rounded-xl hover:scale-105 transition-all shadow-xl hover:shadow-brand-purple/20 group/btn"
                    >
                        GET YOUR GROWTH AUDIT
                        <svg
                            class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                        >
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <div class="grid md:grid-cols-12 gap-y-12 md:gap-x-12 mb-16">
            <!-- Brand Column -->
            <div class="md:col-span-4 lg:col-span-3">
                <a
                    href="/"
                    class="inline-block mb-6 hover:opacity-80 transition-opacity"
                >
                    <Logo class="text-2xl" />
                </a>
                <p
                    class="text-gray-400 leading-relaxed mb-6 text-sm font-medium max-w-[320px]"
                >
                    The Growth Ecosystem for DTC brands scaling from $1M to
                    $50M. Engineering sustainable revenue through unified
                    infrastructure.
                </p>
                <div class="flex items-center gap-6">
                    <a
                        href="https://linkedin.com"
                        class="text-gray-600 hover:text-white transition-all group"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <span class="sr-only">LinkedIn</span>
                        <svg
                            class="w-4 h-4 group-hover:scale-110 transition-transform"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="https://x.com"
                        class="text-gray-600 hover:text-white transition-all group"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <span class="sr-only">X (Twitter)</span>
                        <svg
                            class="w-4 h-4 group-hover:scale-110 transition-transform"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="https://instagram.com"
                        class="text-gray-600 hover:text-white transition-all group"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <span class="sr-only">Instagram</span>
                        <svg
                            class="w-4 h-4 group-hover:scale-110 transition-transform"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308 1.14 1.14 1.14 2.94 1.14 6.459s0 5.319-1.14 6.459c-1.14 1.14-2.94 1.14-6.459 1.14s-5.319 0-6.459-1.14c-1.14-1.14-1.14-2.94-1.14-6.459s0-5.319 1.14-6.459c1.14-1.14 2.94-1.14 6.459-1.14zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948s.014 3.667.072 4.947c.2 4.337 2.617 6.78 6.979 6.98 1.281.058 1.689.072 4.948.072s3.667-.014 4.947-.072c4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948s-.014-3.667-.072-4.947c-.2-4.346-2.617-6.78-6.979-6.98-1.281-.059-1.689-.073-4.948-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Links Sections -->
            <div
                class="md:col-span-8 lg:col-span-9 grid grid-cols-2 sm:grid-cols-3 gap-8 text-sm"
            >
                <div>
                    <h4
                        class="text-white font-black uppercase tracking-[0.2em] mb-6"
                    >
                        Ecosystem
                    </h4>
                    <ul class="space-y-3">
                        {
                            [
                                "Creative Engine",
                                "Media Buying",
                                "Conversion Ops",
                                "Methodology",
                            ].map((link) => (
                                <li>
                                    <a
                                        href={`/ecosystem#${link.toLowerCase().replace(" ", "-")}`}
                                        class="text-gray-500 hover:text-white font-medium transition-all flex items-center gap-2 group"
                                    >
                                        <span class="w-0 h-[1px] bg-brand-purple group-hover:w-3 transition-all" />
                                        {link}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div>
                    <h4
                        class="text-white font-black uppercase tracking-[0.2em] mb-6"
                    >
                        Intelligence
                    </h4>
                    <ul class="space-y-3">
                        {
                            [
                                { label: "Philosophy", href: "/about" },
                                {
                                    label: "Case Studies",
                                    href: "/case-studies",
                                },
                                { label: "Creators", href: "/creators" },
                                { label: "Careers", href: "/careers" },
                            ].map((item) => (
                                <li>
                                    <a
                                        href={item.href}
                                        class="text-gray-500 hover:text-white font-medium transition-all flex items-center gap-2 group"
                                    >
                                        <span class="w-0 h-[1px] bg-brand-blue group-hover:w-3 transition-all" />
                                        {item.label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div>
                    <h4
                        class="text-white font-black uppercase tracking-[0.2em] mb-6"
                    >
                        Frameworks
                    </h4>
                    <ul class="space-y-3">
                        {
                            [
                                { label: "Privacy", href: "/privacy" },
                                { label: "Terms", href: "/terms" },
                                { label: "Guarantee", href: "/#guarantee" },
                            ].map((item) => (
                                <li>
                                    <a
                                        href={item.href}
                                        class="text-gray-500 hover:text-white font-medium transition-all flex items-center gap-2 group"
                                    >
                                        <span class="w-0 h-[1px] bg-brand-green group-hover:w-3 transition-all" />
                                        {item.label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div
            class="border-t border-white/5 pt-10 flex flex-col md:flex-row justify-between items-center gap-6"
        >
            <div class="flex items-center gap-4 order-2 md:order-1">
                <p
                    class="text-[11px] font-bold text-gray-600 uppercase tracking-widest"
                >
                    &copy; {year} OutAfBox Inc / DTC Performance Infrastructure
                </p>
                <div class="hidden md:block w-32 h-[1px] bg-white/5"></div>
            </div>

            <div class="flex items-center gap-3 order-1 md:order-2">
                <div
                    class="flex items-center gap-2 px-3 py-1 rounded-full bg-brand-green/5 border border-brand-green/10 text-[9px] font-bold text-brand-green uppercase tracking-tighter"
                >
                    <span
                        class="w-1 h-1 rounded-full bg-brand-green animate-pulse"
                    ></span>
                    Systems Operational
                </div>
                <div
                    class="flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[9px] font-bold text-gray-400 uppercase tracking-tighter"
                >
                    V 1.0.4
                </div>
            </div>
        </div>
    </div>
</footer>
