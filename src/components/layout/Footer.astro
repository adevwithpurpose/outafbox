---
import Logo from "../brand/Logo.astro";
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-black relative overflow-hidden">
    <!-- Decorative background elements -->
    <div
        class="absolute top-0 left-1/4 w-96 h-96 bg-brand-purple/10 rounded-full blur-[100px] pointer-events-none"
    >
    </div>
    <div
        class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-blue/10 rounded-full blur-[100px] pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-6 pt-20 pb-12 relative z-10">
        <!-- Pre-Footer CTA -->
        <div
            class="glass-panel p-12 rounded-3xl text-center mb-20 border border-white/10 relative overflow-hidden group"
        >
            <div
                class="absolute inset-0 bg-gradient-to-r from-brand-purple/20 to-brand-blue/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700"
            >
            </div>

            <div class="relative z-10">
                <h2
                    class="text-3xl md:text-5xl font-black mb-6 text-white leading-tight"
                >
                    Ready to stop <span class="text-gray-500 line-through"
                        >renting</span
                    > agencies?
                </h2>
                <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
                    Partner with an ecosystem that incentives your growth. We
                    only win when you scale.
                </p>
                <a
                    href="/audit"
                    class="inline-block px-8 py-4 bg-white text-black font-bold rounded-lg hover:scale-105 transition-transform shadow-[0_0_30px_rgba(255,255,255,0.2)]"
                >
                    Get Your Growth Audit
                </a>
            </div>
        </div>

        <div class="grid md:grid-cols-12 gap-12 mb-20">
            <!-- Brand Column -->
            <div class="md:col-span-5">
                <a
                    href="/"
                    class="inline-block mb-6 hover:scale-105 transition-transform"
                >
                    <Logo class="text-3xl" />
                </a>
                <p class="text-gray-400 leading-relaxed mb-6 max-w-sm">
                    The "Anti-Agency" Growth Partner for DTC brands scaling from
                    $1M to $50M. We replace fragmented vendors with a unified
                    revenue infrastructure.
                </p>
                <div class="flex gap-4">
                    <!-- Social Icons (SVGs) -->
                    <a
                        href="https://www.linkedin.com/company/outafbox-studio/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-brand-purple hover:text-white transition-all border border-white/10 hover:border-brand-purple"
                    >
                        <span class="sr-only">LinkedIn</span>
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="https://www.instagram.com/outafbox.studio/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-brand-pink hover:text-white transition-all border border-white/10 hover:border-brand-pink"
                    >
                        <span class="sr-only">Instagram</span>
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="mailto:info@outafbox.com"
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-brand-green hover:text-white transition-all border border-white/10 hover:border-brand-green"
                    >
                        <span class="sr-only">Email</span>
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>

            <!-- Links Column: Ecosystem -->
            <div class="md:col-span-2">
                <h4 class="text-white font-bold mb-6 tracking-wide">
                    Ecosystem
                </h4>
                <ul class="space-y-4 text-gray-400 text-sm">
                    <li>
                        <a
                            href="/ecosystem#creative-engine"
                            class="hover:text-brand-purple transition-colors"
                            >Creative Engine</a
                        >
                    </li>
                    <li>
                        <a
                            href="/ecosystem#media-buying"
                            class="hover:text-brand-purple transition-colors"
                            >Media Buying</a
                        >
                    </li>
                    <li>
                        <a
                            href="/ecosystem#conversion"
                            class="hover:text-brand-purple transition-colors"
                            >Conversion Ops</a
                        >
                    </li>
                    <li>
                        <a
                            href="/ecosystem"
                            class="hover:text-brand-purple transition-colors"
                            >Methodology</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Links Column: Company -->
            <div class="md:col-span-2">
                <h4 class="text-white font-bold mb-6 tracking-wide">Company</h4>
                <ul class="space-y-4 text-gray-400 text-sm">
                    <li>
                        <a
                            href="/about"
                            class="hover:text-brand-purple transition-colors"
                            >Philosophy</a
                        >
                    </li>
                    <li>
                        <a
                            href="/case-studies"
                            class="hover:text-brand-purple transition-colors"
                            >Results</a
                        >
                    </li>
                    <li>
                        <a
                            href="/creators"
                            class="hover:text-brand-purple transition-colors"
                            >For Creators</a
                        >
                    </li>
                    <li>
                        <a
                            href="/careers"
                            class="hover:text-brand-purple transition-colors"
                            >Careers</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Links Column: Legal -->
            <div class="md:col-span-3">
                <h4 class="text-white font-bold mb-6 tracking-wide">Legal</h4>
                <ul class="space-y-4 text-gray-400 text-sm">
                    <li>
                        <a
                            href="/privacy"
                            class="hover:text-brand-purple transition-colors"
                            >Privacy Policy</a
                        >
                    </li>
                    <li>
                        <a
                            href="/terms"
                            class="hover:text-brand-purple transition-colors"
                            >Terms of Service</a
                        >
                    </li>
                    <li>
                        <a
                            href="/#guarantee"
                            class="hover:text-brand-purple transition-colors"
                            >Guarantee Terms</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <div
            class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500"
        >
            <p>&copy; {year} OutAfBox Inc. All rights reserved.</p>
            <div class="flex gap-6 mt-4 md:mt-0">
                <span>Designed by Antigravity</span>
            </div>
        </div>
    </div>
</footer>
