---

<div
    id="growth-ticker"
    class="hidden md:block fixed bottom-6 left-6 z-[100] transform translate-y-20 opacity-0 transition-all duration-700"
>
    <div
        class="glass-panel p-3 pl-4 pr-6 rounded-full border border-white/10 flex items-center gap-4 shadow-2xl bg-black/60 backdrop-blur-xl"
    >
        <div class="relative">
            <div
                class="w-3 h-3 bg-brand-purple rounded-full animate-ping absolute inset-0 opacity-40"
            >
            </div>
            <div class="w-3 h-3 bg-brand-purple rounded-full relative z-10">
            </div>
        </div>

        <div class="flex flex-col">
            <span
                class="text-[10px] font-bold text-gray-500 uppercase tracking-widest leading-none mb-1"
                >Live Ecosystem Status</span
            >
            <span
                id="ticker-text"
                class="text-xs font-bold text-white whitespace-nowrap"
                >Auditing a $5M/yr CPG Brand...</span
            >
        </div>
    </div>
</div>

<script>
    const ticker = document.getElementById("growth-ticker");
    const textEl = document.getElementById("ticker-text");

    const events = [
        "Auditing a $12M/yr Beauty Brand...",
        "Scaling a Footwear Partner at 4.2x ROAS...",
        "Deploying Landing Page V3 for Fashion Client...",
        "UGC Batch 096 delivered to Creator Network...",
        "ROAS stabilizing at 3.8x for Health Partner...",
        "Generated $42k revenue in last 4 hours for Partner B...",
        "Manual Audit complete for Jewelry Brand...",
    ];

    let currentIndex = 0;

    function cycle() {
        if (!ticker || !textEl) return;

        // Hide
        ticker.classList.add("translate-y-20", "opacity-0");

        setTimeout(() => {
            // Update text
            currentIndex = (currentIndex + 1) % events.length;
            textEl.textContent = events[currentIndex];

            // Show
            ticker.classList.remove("translate-y-20", "opacity-0");
        }, 1000);
    }

    // Initial show
    setTimeout(() => {
        if (ticker) ticker.classList.remove("translate-y-20", "opacity-0");
    }, 2000);

    // Initial switch
    setInterval(cycle, 12000);
</script>
