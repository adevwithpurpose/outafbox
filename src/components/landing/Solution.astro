---
const { data } = Astro.props;
---
{
  !data ? (
    <div>Error loading Solution data</div>
  ) : (
    <section class="pt-16 pb-20 relative">
      <!-- Background Elements -->
      <div class="absolute right-0 top-1/3 w-1/3 h-1/3 bg-brand-purple/20 blur-[100px] rounded-full" />
      <div class="absolute left-0 bottom-1/3 w-1/3 h-1/3 bg-brand-blue/20 blur-[100px] rounded-full" />

      <div class="container mx-auto px-6 relative z-10">
        <h2 class="text-4xl md:text-5xl font-black text-center mb-16">
          {data.solutionHeadline}
        </h2>

        {data.variant === 'horizontal' ? (
          <div class="space-y-6 max-w-4xl mx-auto">
            {data.solutionCards &&
              data.solutionCards.map((card: any, index: number) => (
                <div class="glass-panel p-6 md:p-8 rounded-[2rem] flex flex-col md:flex-row items-center gap-8 hover:bg-white/[0.07] transition-all group border border-white/5">
                  <div class="h-16 w-16 shrink-0 bg-gradient-to-br from-brand-purple/20 to-brand-blue/20 rounded-2xl flex items-center justify-center text-3xl shadow-lg border border-white/10 group-hover:scale-110 transition-transform">
                    {card.icon}
                  </div>
                  <div class="text-center md:text-left">
                    <h3 class="text-xl font-bold mb-2 text-white">{card.title}</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">{card.description}</p>
                  </div>
                </div>
              ))}
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
            <div class="hidden md:block absolute top-1/2 left-0 w-full h-1 bg-gradient-to-r from-transparent via-brand-purple/50 to-transparent -translate-y-1/2 z-0" />

            {data.solutionCards &&
              data.solutionCards.map((card: any, index: any) => (
                <div
                  class={`glass-panel p-8 rounded-3xl relative z-10 hover:-translate-y-2 transition-transform duration-300 ${index === 1 ? "border-brand-purple/50 shadow-[0_0_30px_rgba(124,58,237,0.15)]" : ""}`}
                >
                  <div
                    class={`h-16 w-16 ${index === 1 ? "bg-brand-purple/20 shadow-[0_0_15px_rgba(124,58,237,0.3)]" : index === 2 ? "bg-brand-blue/20 shadow-[0_0_15px_rgba(37,99,235,0.3)]" : "bg-brand-pink/20 shadow-[0_0_15px_rgba(219,39,119,0.3)]"} rounded-2xl flex items-center justify-center mb-6 text-3xl`}
                  >
                    {card.icon}
                  </div>
                  <h3 class="text-2xl font-bold mb-4">{card.title}</h3>
                  <p class="text-gray-300">{card.description}</p>
                </div>
              ))}
          </div>
        )}
      </div>
    </section>
  )
}
