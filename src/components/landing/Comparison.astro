---
const { data } = Astro.props;
---

<section class="py-24 relative">
    <div class="container mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-4xl md:text-5xl font-black mb-6">
                The Economics of <span
                    class="bg-gradient-to-r from-brand-purple to-brand-blue bg-clip-text text-transparent"
                    >Growth</span
                >.
            </h2>
            <p class="text-gray-400 text-lg">
                Why building this in-house is a $400k/year liability.
            </p>
        </div>

        <div
            class="grid lg:grid-cols-3 gap-8 items-start max-w-6xl mx-auto pt-8"
        >
            <!-- Option 1: The Traditional Agency -->
            <div
                class="glass-panel p-8 rounded-2xl border-t-2 border-red-500/50 opacity-80 hover:opacity-100 transition-opacity h-full relative"
            >
                <div
                    class="absolute -top-3 left-1/2 -translate-x-1/2 bg-red-500/20 border border-red-500/50 px-3 py-1 rounded-full text-xs text-red-300 uppercase tracking-widest font-bold backdrop-blur-md"
                >
                    High Risk
                </div>
                <h3 class="text-xl font-bold text-gray-300 mb-2 mt-2">
                    Traditional Agency
                </h3>
                <div class="text-3xl font-black text-white mb-1">
                    $5k-$15k<span class="text-sm font-normal text-gray-500"
                        >/mo</span
                    >
                </div>
                <p class="text-xs text-gray-500 mb-6 uppercase tracking-wide">
                    Retainer + % of Spend
                </p>

                <ul class="space-y-4 text-gray-400 text-sm">
                    <li class="flex items-start gap-3">
                        <div
                            class="h-6 w-6 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 text-xs shrink-0"
                        >
                            ✕
                        </div>
                        <span>Disconnected services ("Silos")</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <div
                            class="h-6 w-6 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 text-xs shrink-0"
                        >
                            ✕
                        </div>
                        <span>Misaligned incentives (Retainer)</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <div
                            class="h-6 w-6 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 text-xs shrink-0"
                        >
                            ✕
                        </div>
                        <span>Slow feedback loops</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <div
                            class="h-6 w-6 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 text-xs shrink-0"
                        >
                            ✕
                        </div>
                        <span>No skin in the game</span>
                    </li>
                </ul>

                <div class="mt-8 pt-6 border-t border-white/5 text-center">
                    <div class="text-sm text-gray-500 mb-1">
                        Typical Results
                    </div>
                    <div class="text-lg font-bold text-red-400">
                        1.5-2x ROAS
                    </div>
                </div>
            </div>

            <!-- Option 2: The In-House Team (The Anchor) -->
            <div
                class="glass-panel p-8 rounded-2xl border-t-2 border-yellow-500/50 opacity-80 hover:opacity-100 transition-opacity relative h-full"
            >
                <div
                    class="absolute -top-3 left-1/2 -translate-x-1/2 bg-yellow-500/20 border border-yellow-500/50 px-3 py-1 rounded-full text-xs text-yellow-200 uppercase tracking-widest font-bold backdrop-blur-md"
                >
                    The Expensive Way
                </div>
                <h3 class="text-xl font-bold text-gray-300 mb-2 mt-2">
                    In-House Team
                </h3>
                <div class="text-3xl font-black text-white mb-1">
                    $410k<span class="text-sm font-normal text-gray-500"
                        >/yr</span
                    >
                </div>
                <p class="text-xs text-gray-500 mb-6 uppercase tracking-wide">
                    Payroll + Overhead + Recruiting
                </p>

                <ul class="space-y-4 text-gray-400 text-sm">
                    <li class="flex items-start gap-3">
                        <div
                            class="h-6 w-6 rounded-full bg-yellow-500/20 flex items-center justify-center text-yellow-400 text-xs shrink-0"
                        >
                            !
                        </div>
                        <span>Creative Strategist ($120k)</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <div
                            class="h-6 w-6 rounded-full bg-yellow-500/20 flex items-center justify-center text-yellow-400 text-xs shrink-0"
                        >
                            !
                        </div>
                        <span>Video Editor ($80k)</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <div
                            class="h-6 w-6 rounded-full bg-yellow-500/20 flex items-center justify-center text-yellow-400 text-xs shrink-0"
                        >
                            !
                        </div>
                        <span>Media Buyer ($100k)</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <div
                            class="h-6 w-6 rounded-full bg-yellow-500/20 flex items-center justify-center text-yellow-400 text-xs shrink-0"
                        >
                            !
                        </div>
                        <span>6+ Month Ramp Time</span>
                    </li>
                </ul>

                <div class="mt-8 pt-6 border-t border-white/5 text-center">
                    <div class="text-sm text-gray-500 mb-1">Time to ROI</div>
                    <div class="text-lg font-bold text-yellow-400">
                        12+ Months
                    </div>
                </div>
            </div>

            <!-- Option 3: OutAfBox Ecosystem (The Winner) -->
            <div
                class="glass-panel p-10 rounded-2xl border border-brand-purple shadow-[0_0_50px_rgba(124,58,237,0.15)] relative h-full bg-brand-purple/5"
            >
                <div class="relative z-10">
                    <div
                        class="absolute -top-14 left-1/2 -translate-x-1/2 bg-gradient-to-r from-brand-purple to-brand-pink px-4 py-1 rounded-full text-xs font-bold text-white tracking-widest shadow-lg whitespace-nowrap"
                    >
                        GROWTH PARTNER
                    </div>

                    <h3 class="text-2xl font-bold text-white mb-2">OutAfBox</h3>
                    <div class="text-4xl font-black text-white mb-6">
                        Performance<span
                            class="text-sm font-normal text-gray-400 ml-1"
                            >Based</span
                        >
                    </div>

                    <ul class="space-y-5 text-gray-300">
                        <li class="flex items-start gap-3">
                            <div
                                class="h-6 w-6 rounded-full bg-green-500/20 flex items-center justify-center text-green-400 text-xs"
                            >
                                ✓
                            </div>
                            <span
                                ><strong>Full "Growth Ecosystem"</strong> (Creative
                                + Media + LP)</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <div
                                class="h-6 w-6 rounded-full bg-green-500/20 flex items-center justify-center text-green-400 text-xs"
                            >
                                ✓
                            </div>
                            <span
                                ><strong>Risk Reversal:</strong> We work for free
                                if we miss KPIs</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <div
                                class="h-6 w-6 rounded-full bg-green-500/20 flex items-center justify-center text-green-400 text-xs"
                            >
                                ✓
                            </div>
                            <span>Zero Management Overhead</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <div
                                class="h-6 w-6 rounded-full bg-green-500/20 flex items-center justify-center text-green-400 text-xs"
                            >
                                ✓
                            </div>
                            <span>Asset Ownership (You own the IP)</span>
                        </li>
                    </ul>

                    <div class="mt-8 pt-8 border-t border-white/10 text-center">
                        <div class="text-sm text-gray-400 mb-2">
                            Est. Launch Time
                        </div>
                        <div class="text-xl font-bold text-white">
                            Less than 14 Days
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
