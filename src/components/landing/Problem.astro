---
const { data } = Astro.props;
---
{
  !data ? (
    <div class="text-red-500 p-4">Error: No Data for Problem Section</div>
  ) : (
    <section class="py-24 relative overflow-hidden">
      <div class="container mx-auto px-6 relative z-10">
        <h2 class="text-4xl md:text-6xl font-black text-center mb-16">
          {data.problemHeadline}
          <br />
          <span class="text-red-500 text-glow-red"> 'Ad Fatigue' Wall.</span>
        </h2>

        <div class="grid md:grid-cols-3 gap-8">
          {data.problemCards &&
            data.problemCards.map((card: any) => (
              <div class="glass-panel p-8 rounded-2xl border-l-4 border-l-red-500 hover:bg-white/10 transition-colors group">
                <div class="text-4xl mb-4 grayscale group-hover:grayscale-0 transition-all">
                  {card.icon}
                </div>
                <h3 class="text-2xl font-bold mb-4">{card.title}</h3>
                <p class="text-gray-400">{card.description}</p>
              </div>
            ))}
        </div>
      </div>

      <!-- Red background glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-red-900/5 blur-[120px] pointer-events-none" />
    </section>
  )
}

<style>
  .text-glow-red {
    text-shadow: 0 0 20px rgba(239, 68, 68, 0.6);
  }
</style>
