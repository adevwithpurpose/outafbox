---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>OutAfBox - Growth Ecosystem</title>

		<!-- Font Optimization -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&family=Saira:wght@400;600;700;900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="bg-[#0a0a0a] text-white selection:bg-brand-purple selection:text-white overflow-x-hidden font-sans"
	>
		<Header />
		<slot />
		<Footer />
	</body>
</html>
