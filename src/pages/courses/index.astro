---
import Layout from "../../layouts/Layout.astro";
import moduleMetadata from "../../data/module_metadata.json";

// Define the Module interface
interface CourseItem {
    slug: string;
    title: string;
    type: string;
    subcategory: string;
}

interface Module {
    slug: string;
    name: string;
    subcategories: string[];
    courseCount: number;
    courses: CourseItem[];
}

// Import modules data at runtime
const modulesRaw = await import("../../../output/modules.json");
const modulesData = Array.isArray(modulesRaw.default)
    ? modulesRaw.default
    : [modulesRaw.default];

const modules: Module[] = (modulesData as any[]).map(m => ({
    ...m,
    courseCount: m.courses?.length || 0
})).sort((a, b) => {
    if (a.slug === "new-to-admission-start-here") return -1;
    if (b.slug === "new-to-admission-start-here") return 1;
    return b.courseCount - a.courseCount;
});

function getModuleInfo(slug: string) {
    const meta = (moduleMetadata as Record<string, any>)[slug];
    return {
        description: meta?.description || "Explore our training content",
        icon: meta?.icon || "BookOpen"
    };
}
---

<Layout title="Courses | Training Library">
    <main class="min-h-screen px-6 py-12 bg-[#0A0A0B]">
        <div class="max-w-7xl mx-auto">
            <!-- Header -->
            <header class="mb-16 text-center">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-purple/10 border border-brand-purple/20 text-brand-purple text-xs font-bold uppercase tracking-widest mb-6">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-purple opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-purple"></span>
                    </span>
                    Knowledge Base
                </div>
                <h1 class="text-5xl md:text-7xl font-display font-black mb-6 tracking-tight text-white">
                    Training <span class="text-brand-purple">Library</span>
                </h1>
                <p class="text-gray-400 text-xl max-w-2xl mx-auto font-medium">
                    Master the ecosystem with over 400+ specialized growth trainings and frameworks.
                </p>
                
                <!-- Search Bar -->
                <div class="mt-10 max-w-2xl mx-auto relative group">
                    <div class="absolute inset-0 bg-brand-purple/20 blur-xl group-focus-within:bg-brand-purple/30 transition-all rounded-2xl"></div>
                    <div class="relative flex items-center bg-white/5 border border-white/10 rounded-2xl p-2 backdrop-blur-sm focus-within:border-brand-purple/50 transition-all shadow-2xl">
                        <div class="pl-4 pr-2 text-gray-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <input 
                            type="text" 
                            id="moduleSearch"
                            placeholder="Search modules or specific topics..." 
                            class="w-full bg-transparent border-none focus:ring-0 text-white placeholder-gray-500 py-3 px-2 text-lg"
                        />
                        <div class="hidden md:flex items-center gap-2 pr-4 text-xs font-bold text-gray-600 uppercase">
                            <span class="px-2 py-1 bg-white/5 rounded border border-white/10">ESC</span>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Modules Grid -->
            <section class="mb-20">
                <div class="flex items-end justify-between mb-10">
                    <div>
                        <h2 class="text-3xl font-display font-black text-white mb-2">Modules</h2>
                        <p class="text-gray-500 font-medium">Categorized learning paths for your growth journey</p>
                    </div>
                    <div class="text-gray-500 text-sm font-medium">
                        Showing <span class="text-white font-bold" id="visibleCount">{modules.length}</span> modules
                    </div>
                </div>

                        <div class="flex flex-col gap-4" id="moduleGrid">
                    {
                        modules.map((module) => {
                            const { description, icon } = getModuleInfo(module.slug);
                            const isStartHere = module.slug === "new-to-admission-start-here";

                            return (
                                <a
                                    href={`/courses/${module.slug}`}
                                    data-module-name={module.name.toLowerCase()}
                                    data-module-desc={description.toLowerCase()}
                                    class={
                                        isStartHere
                                            ? "module-card group relative block bg-gradient-to-br from-brand-purple/20 via-brand-purple/5 to-transparent border border-brand-purple/30 rounded-3xl p-8 hover:border-brand-purple/60 transition-all duration-500 overflow-hidden shadow-2xl"
                                            : "module-card group relative block bg-white/[0.03] border border-white/10 rounded-3xl p-8 hover:bg-white/[0.06] hover:border-white/20 transition-all duration-500 overflow-hidden"
                                    }
                                >
                                    {isStartHere && (
                                        <div class="absolute top-0 right-0 px-4 py-1 bg-brand-purple text-white text-[10px] font-black uppercase tracking-widest rounded-bl-xl shadow-lg">
                                            Recommended Start
                                        </div>
                                    )}
                                    
                                    <div class="flex flex-col h-full relative z-10">
                                        <div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-6 transition-transform group-hover:scale-110 duration-500 ${isStartHere ? 'bg-brand-purple/20 border border-brand-purple/30 text-brand-purple shadow-[0_0_20px_rgba(168,85,247,0.2)]' : 'bg-white/5 border border-white/10 text-gray-400'}`}>
                                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                            </svg>
                                        </div>

                                        <h3 class="text-2xl font-display font-black mb-3 text-white group-hover:text-brand-purple transition-colors duration-300">
                                            {module.name}
                                        </h3>
                                        
                                        <p class="text-gray-400 font-medium leading-relaxed mb-8 line-clamp-2">
                                            {description}
                                        </p>
                                        
                                        <div class="mt-auto flex items-center justify-between">
                                            <div class="flex items-center gap-2">
                                                <span class={`px-3 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider border ${isStartHere ? 'bg-brand-purple/20 border-brand-purple/30 text-brand-purple' : 'bg-white/5 border-white/10 text-gray-500 group-hover:text-gray-300'}`}>
                                                    {module.courseCount} Lessons
                                                </span>
                                            </div>
                                            <div class="text-brand-purple translate-x-4 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                                </svg>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Subtle gradient glow -->
                                    <div class="absolute -bottom-20 -right-20 w-40 h-40 bg-brand-purple/10 blur-[60px] rounded-full group-hover:bg-brand-purple/20 transition-all duration-700"></div>
                                </a>
                            );
                        })
                    }
                </div>
                
                <!-- No Results State -->
                <div id="noResults" class="hidden py-20 text-center">
                    <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-white/5 border border-white/10 text-gray-600 mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">No modules found</h3>
                    <p class="text-gray-500">Try adjusting your search terms or browse our recommendations.</p>
                    <button 
                        id="resetSearch"
                        class="mt-6 text-brand-purple font-bold hover:underline"
                    >
                        Clear search
                    </button>
                </div>
            </section>

            <!-- Library Stats -->
            <section class="grid md:grid-cols-3 gap-6 mb-20">
                <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-8 text-center">
                    <div class="text-4xl font-black text-white mb-2 font-display">400+</div>
                    <div class="text-gray-500 font-bold uppercase tracking-widest text-xs">Total Lessons</div>
                </div>
                <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-8 text-center">
                    <div class="text-4xl font-black text-white mb-2 font-display">16</div>
                    <div class="text-gray-500 font-bold uppercase tracking-widest text-xs">Core Modules</div>
                </div>
                <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-8 text-center">
                    <div class="text-4xl font-black text-white mb-2 font-display">24/7</div>
                    <div class="text-gray-500 font-bold uppercase tracking-widest text-xs">Expert Access</div>
                </div>
            </section>
        </div>
    </main>

    <script is:inline>
        const searchInput = document.getElementById('moduleSearch');
        const cards = document.querySelectorAll('.module-card');
        const grid = document.getElementById('moduleGrid');
        const noResults = document.getElementById('noResults');
        const visibleCount = document.getElementById('visibleCount');
        const resetBtn = document.getElementById('resetSearch');

        function filterModules(query) {
            const term = query.toLowerCase().trim();
            let count = 0;

            cards.forEach(card => {
                const name = card.getAttribute('data-module-name');
                const desc = card.getAttribute('data-module-desc');
                
                if (name.includes(term) || desc.includes(term)) {
                    card.style.display = 'block';
                    count++;
                } else {
                    card.style.display = 'none';
                }
            });

            visibleCount.textContent = count;
            
            if (count === 0) {
                grid.style.display = 'none';
                noResults.style.display = 'block';
            } else {
                grid.style.display = 'grid';
                noResults.style.display = 'none';
            }
        }

        searchInput?.addEventListener('input', (e) => filterModules(e.target.value));
        
        resetBtn?.addEventListener('click', () => {
            searchInput.value = '';
            filterModules('');
            searchInput.focus();
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.key === '/' && document.activeElement !== searchInput) {
                e.preventDefault();
                searchInput?.focus();
            }
            if (e.key === 'Escape') {
                searchInput.value = '';
                filterModules('');
                searchInput?.blur();
            }
        });
    </script>
</Layout>

                
