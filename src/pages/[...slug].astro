---
import { client } from "../../tina/__generated__/client";
import Layout from "../layouts/Layout.astro";
import PageBuilder from "../components/PageBuilder.astro";

// Fetch all CMS-managed pages at build time for static generation
export async function getStaticPaths() {
    try {
        const pagesResponse = await client.queries.pageConnection();
        const pages = pagesResponse.data?.pageConnection?.edges ?? [];

        return pages
            .map((edge: any) => {
                const slug = edge?.node?._sys?.filename;
                if (!slug) return null;
                // Exclude pages that have their own dedicated .astro files
                const excludedSlugs = [
                    "home",
                    "about",
                    "privacy",
                    "terms",
                    "case-studies",
                    "ecosystem",
                    "audit",
                    "careers",
                    "creators",
                ];
                if (excludedSlugs.includes(slug)) return null;
                return {
                    params: { slug },
                    props: { page: edge.node },
                };
            })
            .filter(Boolean);
    } catch (e) {
        // If TinaCMS is unavailable at build time, return empty (no dynamic pages)
        console.warn("[...slug].astro: Could not fetch pages from TinaCMS:", e);
        return [];
    }
}

const { slug } = Astro.params;
const { page } = Astro.props;
---

{
    page ? (
        <Layout title={page.title}>
            <main class="min-h-screen">
                <PageBuilder blocks={page.blocks} />
            </main>
        </Layout>
    ) : (
        <Layout title="Not Found">
            <main class="min-h-screen flex items-center justify-center">
                <p class="text-white text-xl">Page not found</p>
            </main>
        </Layout>
    )
}
