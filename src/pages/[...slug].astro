---
import { client } from "../../tina/__generated__/client";
import Layout from "../layouts/Layout.astro";
import PageBuilder from "../components/PageBuilder.astro";

// Disable static generation - use server-side rendering for all paths
export async function getStaticPaths() {
    return [];
}
export const prerender = false;

const { slug } = Astro.params;

const slug_str = slug as string;
// If slug is 'courses' or starts with 'courses/', return a 404 to let other routes handle it.
if (slug_str && (slug_str === "courses" || slug_str.startsWith("courses/"))) {
    return new Response(null, {
        status: 404,
        statusText: "Not Found",
    });
}

// If slug is empty, return 404 (handled by index.astro)
if (!slug) {
    throw new Response("Not found", { status: 404 });
}

// Fetch page from TinaCMS at runtime
const response = await client.queries.page({ relativePath: `${slug}.md` });
const { data } = response;

// If page not found in TinaCMS, return 404
if (!data.page) {
    throw new Response("Page not found", { status: 404 });
}
---

<Layout title={data.page.title}>
    <main class="min-h-screen">
        <PageBuilder blocks={data.page.blocks} />
    </main>
</Layout>
